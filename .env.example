# ─────────────────────────────────────────────────────────────
#  .env.example -- environment-variable template
#  Usage:  cp .env.example .env   then edit .env and fill in your real keys
#  Notes:  .env is ignored by .gitignore (never committed, never leaked); this template
#          is committed so anyone (and future-you) can see at a glance which keys are needed.
# ─────────────────────────────────────────────────────────────

# Default provider is qwen (see `active` in models.yaml) → this one is required
# (the international DashScope endpoint).
DASHSCOPE_API_KEY=your-dashscope-intl-key-here

# Only needed when switching to another provider (change active / *_override in models.yaml).
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Optional: cross-platform / local-model overrides ────────────────────────
# When none are set, it is automatic: Apple Silicon → local ~/models + MLX;
# other platforms → auto-download from HuggingFace.
# EMBED_BACKEND=auto            # auto | mlx | st (sentence-transformers, cross-platform/GPU)
# EMBED_MODEL=BAAI/bge-m3
# RERANKER_MODEL=BAAI/bge-reranker-v2-m3
