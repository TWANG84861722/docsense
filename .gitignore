# ═══════════════════════════════════════════════════════════
#  .gitignore —— 告诉 git 哪些不要纳入版本控制
#  原则：提交"菜谱"(代码/配置模板/依赖)，不提交"菜"(产物)和"钥匙"(密钥)
#  ⚠️ gitignore 不支持"行尾注释"！注释必须单独成行，否则会被当成匹配模式。
# ═══════════════════════════════════════════════════════════

# Python 自动生成的东西
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# 虚拟环境（1.7G，各自 pip install 重建）
.venv/
venv/

# 密钥：绝对不能提交！（改用 .env.example 当模板）
.env

# 操作系统 / 编辑器 杂物
.DS_Store
.idea/
.vscode/

# 产物：能重新生成，不进库
# index_chunk*：跑 ingest.py 重建；*.bak：备份；data/：源 PDF（大 + 版权）
index_chunk*/
*.bak
data/

# 昂贵缓存：能重建但要花钱(VL)/联网(MyGene)。忽略≠删除，想留就自己另拷备份
vl_cache/
db/

# AI / 工具状态
.claude/
